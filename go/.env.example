# Токен бота от @BotFather
BOT_TOKEN=789123:AAH...

# Куда дублировать error-логи бота в Telegram. Если не задавать —
# отправка логов в чат отключена.
# Для обычной группы/супергруппы достаточно ERROR_LOG_CHAT_ID.
# Для форум-группы с темами можно дополнительно указать
# ERROR_LOG_MESSAGE_THREAD_ID, чтобы логи шли в конкретную тему.
# ERROR_LOG_CHAT_ID=-1001234567890
# ERROR_LOG_MESSAGE_THREAD_ID=123
# Если проблема не решилась, бот будет напоминать о ней в Telegram.
# По умолчанию — раз в 30 минут.
ERROR_LOG_REMINDER_MINUTES=30

# Антифлуд: не более RATE_LIMIT_COUNT сообщений за RATE_LIMIT_WINDOW_SECONDS
# от одного пользователя. При превышении — сообщение удаляется, автор
# банится с отзывом (удалением) его недавних сообщений. Необязательные,
# указаны значения по умолчанию.
RATE_LIMIT_COUNT=5
RATE_LIMIT_WINDOW_SECONDS=3

# Пул воркеров, разбирающих очередь входящих сообщений. Необязательные,
# указаны значения по умолчанию.
WORKER_COUNT=10
QUEUE_SIZE=5000

# Webhook (необязательно). Если WEBHOOK_URL не задан — бот работает через
# Long Polling (по умолчанию, ничего настраивать не нужно). Если задан —
# бот регистрирует webhook в Telegram и поднимает HTTP-сервер вместо
# long polling. WEBHOOK_URL — это публичный https-адрес, на который
# Telegram шлёт апдейты; почти всегда это домен с TLS-сертификатом и
# reverse-proxy (nginx/Caddy), который проксирует на WEBHOOK_LISTEN_ADDR
# (сам бот отдаёт обычный HTTP, TLS он не терминирует).
# WEBHOOK_URL=https://example.com/webhook
# WEBHOOK_SECRET_TOKEN=сгенерируйте_длинную_случайную_строку
# WEBHOOK_LISTEN_ADDR=:8080
# WEBHOOK_PATH=/webhook

# PostgreSQL для глобального обучения (необязательно). Если не задан — бот
# работает только на in-memory rate-limit, как раньше. Если задан, но БД
# недоступна при старте — бот тоже не упадёт, просто продолжит без
# глобального чёрного списка (см. README, разделы "Глобальное обучение" и
# "Проверка ссылок по домену"). Та же БД используется и для проверки ссылок
# по домену (без внешних API вроде VirusTotal) — отдельной переменной для
# неё не требуется.
# При использовании docker-compose (сервис db из docker-compose.yml) хост —
# имя сервиса, а не localhost:
# DATABASE_URL=postgres://antispam:antispam@db:5432/antispam?sslmode=disable

# Обучение через жалобы: команда /report в ответ на сообщение засчитывается
# как голос. Когда на одно и то же сообщение пожалуются REPORT_THRESHOLD
# разных пользователей — автор банится, текст уходит в глобальное обучение
# (если DATABASE_URL задан). Необязательный, минимум 2, по умолчанию 3.
REPORT_THRESHOLD=3

# Тихий режим: если true, бот не пишет в чат уведомление о бане
# ("🚫 Пользователь X забанен..."). Удаление/бан/обучение происходят как
# обычно — меняется только видимость для чата.
# Кодовый дефолт при отсутствии переменной: false.
# В этом шаблоне сразу включён тихий режим:
SILENT_BAN=true

# Фильтр по словам (команды /addspam, /removespam, /triggers — только для
# админов чата). Требует DATABASE_URL: без БД фильтр отключён, команды
# ответят понятным сообщением вместо тихого игнорирования. WARN_THRESHOLD —
# сколько сообщений с триггер-словом подряд допускается, прежде чем бан
# вместо очередного предупреждения. Необязательный, минимум 1, по умолчанию 3.
WARN_THRESHOLD=3

# Встроенный эвристический фильтр "плохого контекста": ловит типичный
# скам/казино/интим-спам, если в сообщении одновременно есть подозрительная
# тема и ссылка/@username/призыв писать в личку. Не требует PostgreSQL и
# включён по умолчанию.
CONTENT_FILTER_ENABLED=true
# Что делать при срабатывании встроенного фильтра:
# ban    — удалить сообщение и забанить автора
# delete — только удалить сообщение без бана
CONTENT_FILTER_ACTION=ban
# Необязательный allowlist для встроенного фильтра: если сообщение содержит
# одну из этих подстрок, эвристика плохого контекста его пропустит.
# Удобно для легитимных рекламных/рабочих формулировок именно вашего чата.
# Формат: значения через запятую.
# CONTENT_FILTER_ALLOW_SUBSTRINGS=ставок ЦБ,пассивный доход компании,пиши в лс менеджеру проекта

# Капча для новых участников чата: сразу после вступления пользователь
# мутится и должен подтвердить, что не бот, нажав кнопку — иначе кик по
# истечении CAPTCHA_TIMEOUT_SECONDS. Требует у бота права "Restrict members"
# (см. README).
# Кодовый дефолт при отсутствии CAPTCHA_ENABLED: true.
# В этом шаблоне капча по умолчанию отключена, чтобы старт был проще:
# CAPTCHA_TIMEOUT_SECONDS по коду по умолчанию 120.
CAPTCHA_ENABLED=false
CAPTCHA_TIMEOUT_SECONDS=120

# Автоудаление: через сколько секунд после отправки удалять и команду
# администратора, и ответ бота — только в групповых чатах (в личных сообщения
# не трогаются). Чтобы отключить — поставьте 0. Необязательный, по умолчанию 30.
AUTO_DELETE_DELAY_SECONDS=30
