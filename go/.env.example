# Токен бота от @BotFather
BOT_TOKEN=789123:AAH...

# Антифлуд: не более RATE_LIMIT_COUNT сообщений за RATE_LIMIT_WINDOW_SECONDS
# от одного пользователя. При превышении — сообщение удаляется, автор
# банится с отзывом (удалением) его недавних сообщений. Необязательные,
# указаны значения по умолчанию.
RATE_LIMIT_COUNT=5
RATE_LIMIT_WINDOW_SECONDS=3

# Пул воркеров, разбирающих очередь входящих сообщений. Необязательные,
# указаны значения по умолчанию.
WORKER_COUNT=10
QUEUE_SIZE=5000

# Webhook (необязательно). Если WEBHOOK_URL не задан — бот работает через
# Long Polling (по умолчанию, ничего настраивать не нужно). Если задан —
# бот регистрирует webhook в Telegram и поднимает HTTP-сервер вместо
# long polling. WEBHOOK_URL — это публичный https-адрес, на который
# Telegram шлёт апдейты; почти всегда это домен с TLS-сертификатом и
# reverse-proxy (nginx/Caddy), который проксирует на WEBHOOK_LISTEN_ADDR
# (сам бот отдаёт обычный HTTP, TLS он не терминирует).
# WEBHOOK_URL=https://example.com/webhook
# WEBHOOK_SECRET_TOKEN=сгенерируйте_длинную_случайную_строку
# WEBHOOK_LISTEN_ADDR=:8080
# WEBHOOK_PATH=/webhook

# PostgreSQL для глобального обучения (необязательно). Если не задан — бот
# работает только на in-memory rate-limit, как раньше. Если задан, но БД
# недоступна при старте — бот тоже не упадёт, просто продолжит без
# глобального чёрного списка (см. README, раздел "Глобальное обучение").
# При использовании docker-compose (сервис db из docker-compose.yml) хост —
# имя сервиса, а не localhost:
# DATABASE_URL=postgres://antispam:antispam@db:5432/antispam?sslmode=disable

# Обучение через жалобы: команда /report в ответ на сообщение засчитывается
# как голос. Когда на одно и то же сообщение пожалуются REPORT_THRESHOLD
# разных пользователей — автор банится, текст уходит в глобальное обучение
# (если DATABASE_URL задан). Необязательный, минимум 2, по умолчанию 3.
REPORT_THRESHOLD=3
